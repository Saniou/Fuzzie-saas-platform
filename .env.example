# ─────────────────────────────────────────────────────────────
# Fuzzie SaaS — приклад змінних оточення.
# Скопіюй у `.env` і заповни реальними значеннями.
# ─────────────────────────────────────────────────────────────

# Базовий публічний URL застосунку (для redirect-ів Stripe тощо).
# Локально звичайно http://localhost:3000, у проді — домен.
NEXT_PUBLIC_URL=http://localhost:3000

# ── База даних (PostgreSQL / Neon) ──────────────────────────
DATABASE_URL="postgresql://neondb_owner:nNZ4HXx1CPmT@ep-odd-lab-a5e54zmb.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Clerk (автентифікація) ──────────────────────────────────

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_dXNlZnVsLW1vbmtmaXNoLTU2LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_sT0iNdMzwhgKlNPfpaZ60NqS285PiwD1yLZJDePz17

# ── Stripe (підписки / білінг) ──────────────────────────────
STRIPE_SECRET=sk_test_xxx

# ── Uploadcare (завантаження файлів) ────────────────────────
NEXT_PUBLIC_UPLOADCARE_PUBLIC_KEY=xxx

# ── Google Drive (OAuth + drive activity) ───────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
OAUTH2_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
# Тимчасовий токен для тестового /api/drive ендпоінта
GOOGLE_ACCESS_TOKEN=xxx

# ── Discord (OAuth + webhooks) ──────────────────────────────
DISCORD_CLIENT_ID=xxx
DISCORD_CLIENT_SECRET=xxx
# Повний OAuth-URL кнопки підключення Discord
NEXT_PUBLIC_DISCORD_REDIRECT=https://discord.com/oauth2/authorize?client_id=...

# ── Notion (OAuth) ──────────────────────────────────────────
NOTION_CLIENT_ID=xxx
NOTION_API_SECRET=xxx
NOTION_REDIRECT_URI=http://localhost:3000/api/auth/callback/notion
# Повний OAuth-URL кнопки підключення Notion
NEXT_PUBLIC_NOTION_AUTH_URL=https://api.notion.com/v1/oauth/authorize?client_id=...

# ── Slack (OAuth) ───────────────────────────────────────────
SLACK_CLIENT_ID=xxx
SLACK_CLIENT_SECRET=xxx
SLACK_REDIRECT_URI=http://localhost:3000/api/auth/callback/slack
# Повний OAuth-URL кнопки підключення Slack
NEXT_PUBLIC_SLACK_REDIRECT=https://slack.com/oauth/v2/authorize?client_id=...

# ── Ngrok / Cron (вебхуки Google Drive + Wait-таймер) ───────
# БАЗОВИЙ публічний HTTPS-origin (ngrok), БЕЗ шляху — код сам додає
# /api/drive-activity/notification (тригер) та /api/cron/wait (крок Wait).
NGROK_URI=https://your-ngrok-subdomain.ngrok-free.app
# Ключ cron-job.org для відкладеного кроку "Wait".
CRON_JOB_KEY=xxx

# ПРИМІТКА: redirect_uri OAuth-callback'ів тепер береться з NEXT_PUBLIC_URL —
# зареєструй той самий URL у dev-консолях Discord/Slack/Notion.
